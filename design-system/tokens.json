{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Jofi Pet — Quiz Campaign Design System v1.0. Source of truth. Toda decoração, web ou social, lê DESTE arquivo. Hardcoded values = bug.",
  "$metadata": {
    "version": "1.0.0",
    "owner": "design-sys-eng (Diana)",
    "consumes": ["April Dunford positioning", "Emily Heyward brand soul", "Sagi Haviv visual direction"],
    "consumed_by": ["tailwind.config.ts", "app/globals.css", "design-system/README.md", "Figma library (futuro)"]
  },

  "color": {
    "$description": "Two-tier system. PRIMITIVE = paleta crua. SEMANTIC = uso contextual. Componentes consomem APENAS semantic.",

    "primitive": {
      "coral": {
        "50":  { "$value": "#FFF1ED", "$type": "color" },
        "100": { "$value": "#FFE0D5", "$type": "color" },
        "300": { "$value": "#FFB39E", "$type": "color" },
        "500": { "$value": "#FF7A59", "$type": "color", "$description": "Marca-âncora. 10% de cobertura por peça (regra Haviv)." },
        "600": { "$value": "#E3594A", "$type": "color", "$description": "Hover/pressed." },
        "700": { "$value": "#B8392F", "$type": "color", "$description": "Texto coral em fundo cream — atinge AA 4.5:1." }
      },
      "cream": {
        "50":  { "$value": "#FFF7F0", "$type": "color", "$description": "Background canônico. NÃO usar #FFF puro." }
      },
      "warmYellow": {
        "300": { "$value": "#FFE3A3", "$type": "color" },
        "500": { "$value": "#FFD66B", "$type": "color", "$description": "Acento. Uso ≤3%." },
        "700": { "$value": "#7A5A00", "$type": "color", "$description": "Texto sobre amarelo — AA." }
      },
      "trustGreen": {
        "300": { "$value": "#A8DEC2", "$type": "color" },
        "500": { "$value": "#4CAF82", "$type": "color", "$description": "Sucesso/calma. Funcional, NÃO marca." },
        "700": { "$value": "#1F6B47", "$type": "color" }
      },
      "whatsapp": {
        "500": { "$value": "#25D366", "$type": "color", "$description": "Convenção de plataforma. EXCLUSIVO do CTA WhatsApp." },
        "600": { "$value": "#1EBE5A", "$type": "color" }
      },
      "warmBlack": {
        "100": { "$value": "#F6F2EE", "$type": "color" },
        "300": { "$value": "#DDD4CE", "$type": "color" },
        "500": { "$value": "#8D847E", "$type": "color" },
        "700": { "$value": "#5C524C", "$type": "color" },
        "900": { "$value": "#2D2520", "$type": "color", "$description": "Texto canônico. NÃO usar #000 puro." }
      },
      "alert": {
        "warn":  { "$value": "#FFA83D", "$type": "color" },
        "error": { "$value": "#E3594A", "$type": "color" }
      }
    },

    "semantic": {
      "$description": "É AQUI que componentes leem. Trocar paleta = trocar primitive; semantic não muda.",

      "background": {
        "canvas":     { "$value": "{color.primitive.cream.50}", "$type": "color", "$description": "Fundo de página, hero, qualquer respiração." },
        "surface":    { "$value": "#FFFFFF", "$type": "color", "$description": "Cards e inputs sobre canvas. Único lugar onde branco puro é permitido." },
        "muted":      { "$value": "{color.primitive.warmBlack.100}", "$type": "color", "$description": "Seções de quebra (FAQ, footer)." },
        "inverse":    { "$value": "{color.primitive.warmBlack.900}", "$type": "color", "$description": "Footer institucional, modais escuros." }
      },

      "text": {
        "primary":    { "$value": "{color.primitive.warmBlack.900}", "$type": "color" },
        "secondary":  { "$value": "{color.primitive.warmBlack.700}", "$type": "color" },
        "muted":      { "$value": "{color.primitive.warmBlack.500}", "$type": "color", "$description": "Microcopy, captions." },
        "onAccent":   { "$value": "#FFFFFF", "$type": "color", "$description": "Sobre coral 500/600 e WhatsApp 500." },
        "onYellow":   { "$value": "{color.primitive.warmBlack.900}", "$type": "color", "$description": "Amarelo é claro — texto escuro." },
        "link":       { "$value": "{color.primitive.coral.700}", "$type": "color", "$description": "AA-safe sobre cream." }
      },

      "border": {
        "subtle":     { "$value": "{color.primitive.warmBlack.300}", "$type": "color" },
        "default":    { "$value": "{color.primitive.warmBlack.500}", "$type": "color" },
        "focus":      { "$value": "{color.primitive.coral.500}", "$type": "color" },
        "selected":   { "$value": "{color.primitive.coral.500}", "$type": "color" }
      },

      "action": {
        "primary":         { "$value": "{color.primitive.coral.500}", "$type": "color", "$description": "CTA principal único por viewport." },
        "primaryHover":    { "$value": "{color.primitive.coral.600}", "$type": "color" },
        "primarySoft":     { "$value": "{color.primitive.coral.100}", "$type": "color", "$description": "Estado selected de QuizOption." },
        "secondary":       { "$value": "transparent", "$type": "color", "$description": "Botão ghost, borda primary." },
        "whatsapp":        { "$value": "{color.primitive.whatsapp.500}", "$type": "color" },
        "whatsappHover":   { "$value": "{color.primitive.whatsapp.600}", "$type": "color" }
      },

      "feedback": {
        "success":         { "$value": "{color.primitive.trustGreen.500}", "$type": "color" },
        "successSurface":  { "$value": "{color.primitive.trustGreen.300}", "$type": "color" },
        "warning":         { "$value": "{color.primitive.alert.warn}", "$type": "color" },
        "warningSurface":  { "$value": "{color.primitive.warmYellow.300}", "$type": "color" },
        "error":           { "$value": "{color.primitive.alert.error}", "$type": "color" }
      },

      "tier": {
        "$description": "Regra Haviv §2: cor reforça veredito do quiz. Frio usa verde como CALMA, não como marca.",
        "hot":   { "$value": "{color.primitive.coral.500}", "$type": "color" },
        "warm":  { "$value": "{color.primitive.warmYellow.500}", "$type": "color" },
        "cold":  { "$value": "{color.primitive.trustGreen.500}", "$type": "color" }
      },

      "highlight": {
        "$description": "Para grifo de 1 palavra-âncora em headline. Use APENAS em uma palavra por bloco.",
        "anchor":      { "$value": "{color.primitive.coral.500}", "$type": "color" },
        "anchorBg":    { "$value": "{color.primitive.warmYellow.500}", "$type": "color", "$description": "Marca-texto opcional, ~3px de underline ou pintura." }
      }
    }
  },

  "typography": {
    "$description": "Uma família. Três pesos. A disciplina é: H1=800, H2/Bold inline=700, Body=400. Tudo que sair disso é bug.",

    "fontFamily": {
      "sans": { "$value": "var(--font-nunito), 'Nunito', system-ui, -apple-system, sans-serif", "$type": "fontFamily" }
    },

    "fontWeight": {
      "regular":   { "$value": 400, "$type": "fontWeight" },
      "semibold":  { "$value": 600, "$type": "fontWeight", "$description": "Caption/microcopy apenas." },
      "bold":      { "$value": 700, "$type": "fontWeight" },
      "extrabold": { "$value": 800, "$type": "fontWeight", "$description": "H1 only." }
    },

    "fontSize": {
      "$description": "Escala modular 1.125 (major second) ajustada para leitura mobile-first. 11 steps suficientes — não inventar mais.",
      "xs":   { "$value": "12px",  "$type": "dimension" },
      "sm":   { "$value": "14px",  "$type": "dimension" },
      "base": { "$value": "16px",  "$type": "dimension" },
      "md":   { "$value": "17px",  "$type": "dimension", "$description": "Body desktop. +1px aumenta legibilidade sem mudar ritmo." },
      "lg":   { "$value": "20px",  "$type": "dimension" },
      "xl":   { "$value": "24px",  "$type": "dimension" },
      "2xl":  { "$value": "28px",  "$type": "dimension" },
      "3xl":  { "$value": "32px",  "$type": "dimension", "$description": "H1 mobile." },
      "4xl":  { "$value": "40px",  "$type": "dimension", "$description": "H1 desktop." },
      "5xl":  { "$value": "48px",  "$type": "dimension", "$description": "Hero institucional. Uso raro." },
      "6xl":  { "$value": "56px",  "$type": "dimension", "$description": "Reels frame 1." }
    },

    "lineHeight": {
      "tight":   { "$value": 1.1, "$type": "number", "$description": "Headlines display." },
      "snug":    { "$value": 1.2, "$type": "number", "$description": "H1, H2." },
      "normal":  { "$value": 1.4, "$type": "number", "$description": "Subheadlines, lead text." },
      "relaxed": { "$value": 1.5, "$type": "number", "$description": "Body. Oxigênio = legibilidade." }
    },

    "letterSpacing": {
      "tight":   { "$value": "-0.01em", "$type": "dimension" },
      "snug":    { "$value": "-0.005em", "$type": "dimension" },
      "normal":  { "$value": "0",       "$type": "dimension" },
      "wide":    { "$value": "0.01em",  "$type": "dimension", "$description": "CTA labels — labels curtos respiram." }
    },

    "textStyle": {
      "$description": "Composições prontas. Componentes consomem text styles, não props soltas.",

      "displayHero": {
        "$type": "typography",
        "$value": {
          "fontFamily":   "{typography.fontFamily.sans}",
          "fontWeight":   "{typography.fontWeight.extrabold}",
          "fontSize":     "{typography.fontSize.3xl}",
          "lineHeight":   "{typography.lineHeight.snug}",
          "letterSpacing": "{typography.letterSpacing.tight}"
        }
      },
      "displayHeroDesktop": {
        "$type": "typography",
        "$value": {
          "fontFamily":   "{typography.fontFamily.sans}",
          "fontWeight":   "{typography.fontWeight.extrabold}",
          "fontSize":     "{typography.fontSize.4xl}",
          "lineHeight":   "{typography.lineHeight.snug}",
          "letterSpacing": "{typography.letterSpacing.tight}"
        }
      },
      "h1": {
        "$type": "typography",
        "$value": {
          "fontFamily":   "{typography.fontFamily.sans}",
          "fontWeight":   "{typography.fontWeight.extrabold}",
          "fontSize":     "{typography.fontSize.3xl}",
          "lineHeight":   "{typography.lineHeight.snug}",
          "letterSpacing": "{typography.letterSpacing.tight}"
        }
      },
      "h2": {
        "$type": "typography",
        "$value": {
          "fontFamily":   "{typography.fontFamily.sans}",
          "fontWeight":   "{typography.fontWeight.bold}",
          "fontSize":     "{typography.fontSize.xl}",
          "lineHeight":   "{typography.lineHeight.snug}",
          "letterSpacing": "{typography.letterSpacing.snug}"
        }
      },
      "h3": {
        "$type": "typography",
        "$value": {
          "fontFamily":   "{typography.fontFamily.sans}",
          "fontWeight":   "{typography.fontWeight.bold}",
          "fontSize":     "{typography.fontSize.lg}",
          "lineHeight":   "{typography.lineHeight.snug}",
          "letterSpacing": "{typography.letterSpacing.normal}"
        }
      },
      "lead": {
        "$type": "typography",
        "$description": "Subheadline do hero, intro de seção.",
        "$value": {
          "fontFamily":   "{typography.fontFamily.sans}",
          "fontWeight":   "{typography.fontWeight.regular}",
          "fontSize":     "{typography.fontSize.lg}",
          "lineHeight":   "{typography.lineHeight.normal}",
          "letterSpacing": "{typography.letterSpacing.normal}"
        }
      },
      "body": {
        "$type": "typography",
        "$value": {
          "fontFamily":   "{typography.fontFamily.sans}",
          "fontWeight":   "{typography.fontWeight.regular}",
          "fontSize":     "{typography.fontSize.base}",
          "lineHeight":   "{typography.lineHeight.relaxed}",
          "letterSpacing": "{typography.letterSpacing.normal}"
        }
      },
      "bodyEmphasis": {
        "$type": "typography",
        "$value": {
          "fontFamily":   "{typography.fontFamily.sans}",
          "fontWeight":   "{typography.fontWeight.bold}",
          "fontSize":     "{typography.fontSize.base}",
          "lineHeight":   "{typography.lineHeight.relaxed}",
          "letterSpacing": "{typography.letterSpacing.normal}"
        }
      },
      "label": {
        "$type": "typography",
        "$description": "CTA, chips, labels de form.",
        "$value": {
          "fontFamily":   "{typography.fontFamily.sans}",
          "fontWeight":   "{typography.fontWeight.bold}",
          "fontSize":     "{typography.fontSize.base}",
          "lineHeight":   "{typography.lineHeight.tight}",
          "letterSpacing": "{typography.letterSpacing.wide}"
        }
      },
      "caption": {
        "$type": "typography",
        "$description": "Microcopy abaixo de CTA, redutor de fricção.",
        "$value": {
          "fontFamily":   "{typography.fontFamily.sans}",
          "fontWeight":   "{typography.fontWeight.semibold}",
          "fontSize":     "{typography.fontSize.sm}",
          "lineHeight":   "{typography.lineHeight.normal}",
          "letterSpacing": "{typography.letterSpacing.normal}"
        }
      },
      "kicker": {
        "$type": "typography",
        "$description": "Eyebrow/kicker acima do H1. CAPS permitido (≤3 palavras).",
        "$value": {
          "fontFamily":   "{typography.fontFamily.sans}",
          "fontWeight":   "{typography.fontWeight.bold}",
          "fontSize":     "{typography.fontSize.sm}",
          "lineHeight":   "{typography.lineHeight.tight}",
          "letterSpacing": "0.08em",
          "textTransform": "uppercase"
        }
      },
      "price": {
        "$type": "typography",
        "$description": "Numerais tabular para R$49,90 alinhar verticalmente.",
        "$value": {
          "fontFamily":   "{typography.fontFamily.sans}",
          "fontWeight":   "{typography.fontWeight.extrabold}",
          "fontSize":     "{typography.fontSize.2xl}",
          "lineHeight":   "{typography.lineHeight.tight}",
          "letterSpacing": "{typography.letterSpacing.tight}",
          "fontFeatureSettings": "'tnum' 1, 'lnum' 1"
        }
      }
    }
  },

  "spacing": {
    "$description": "Escala 4px-base. Não interpolar entre steps. Se precisar de algo entre 16 e 24, use 20 — está aqui.",
    "0":   { "$value": "0",     "$type": "dimension" },
    "1":   { "$value": "4px",   "$type": "dimension" },
    "2":   { "$value": "8px",   "$type": "dimension" },
    "3":   { "$value": "12px",  "$type": "dimension" },
    "4":   { "$value": "16px",  "$type": "dimension" },
    "5":   { "$value": "20px",  "$type": "dimension" },
    "6":   { "$value": "24px",  "$type": "dimension" },
    "8":   { "$value": "32px",  "$type": "dimension" },
    "10":  { "$value": "40px",  "$type": "dimension" },
    "12":  { "$value": "48px",  "$type": "dimension" },
    "16":  { "$value": "64px",  "$type": "dimension" },
    "20":  { "$value": "80px",  "$type": "dimension" },
    "24":  { "$value": "96px",  "$type": "dimension" },
    "32":  { "$value": "128px", "$type": "dimension" }
  },

  "size": {
    "$description": "Tamanhos canônicos de targets de toque, alturas de componente e larguras de container.",
    "tap":           { "$value": "44px",  "$type": "dimension", "$description": "Target mínimo iOS HIG." },
    "tapComfort":    { "$value": "56px",  "$type": "dimension", "$description": "QuizOption, CTA principal." },
    "ctaHeight":     { "$value": "56px",  "$type": "dimension" },
    "inputHeight":   { "$value": "52px",  "$type": "dimension" },
    "iconSm":        { "$value": "16px",  "$type": "dimension" },
    "iconMd":        { "$value": "20px",  "$type": "dimension" },
    "iconLg":        { "$value": "24px",  "$type": "dimension" },
    "logoMin":       { "$value": "24px",  "$type": "dimension", "$description": "Regra Haviv §4: abaixo disso, símbolo sem wordmark." },
    "containerMobile":  { "$value": "420px", "$type": "dimension" },
    "containerDesktop": { "$value": "600px", "$type": "dimension" },
    "containerWide":    { "$value": "1120px","$type": "dimension", "$description": "Apenas para grids 3-cols (differentiators)." }
  },

  "radius": {
    "none":  { "$value": "0",     "$type": "dimension" },
    "sm":    { "$value": "8px",   "$type": "dimension" },
    "md":    { "$value": "12px",  "$type": "dimension" },
    "lg":    { "$value": "16px",  "$type": "dimension", "$description": "Card padrão. Acolhimento sem soft-blob." },
    "xl":    { "$value": "24px",  "$type": "dimension", "$description": "Hero card, modal." },
    "pill":  { "$value": "9999px","$type": "dimension", "$description": "Botões e chips." }
  },

  "elevation": {
    "$description": "Sombras curtas e quentes. Marca acolhedora não usa drop-shadow estilo SaaS-azulado.",
    "0": { "$value": "none", "$type": "shadow" },
    "1": {
      "$type": "shadow",
      "$value": "0 1px 2px 0 rgba(45, 37, 32, 0.06)",
      "$description": "Card em repouso."
    },
    "2": {
      "$type": "shadow",
      "$value": "0 2px 8px 0 rgba(45, 37, 32, 0.08)",
      "$description": "Card hover, dropdown."
    },
    "3": {
      "$type": "shadow",
      "$value": "0 8px 24px -4px rgba(45, 37, 32, 0.12)",
      "$description": "CTA destacado, modal."
    },
    "focus": {
      "$type": "shadow",
      "$value": "0 0 0 3px rgba(255, 122, 89, 0.32)",
      "$description": "Anel de foco do CTA primário."
    }
  },

  "motion": {
    "$description": "Durações curtas. Microinterações precisam ser sentidas, não exibidas. v1.1: estendido com spring configs físicos (matt) e choreography variants.",

    "duration": {
      "instant": { "$value": "80ms",  "$type": "duration", "$description": "Tap feedback (whileTap framer)." },
      "fast":    { "$value": "150ms", "$type": "duration" },
      "base":    { "$value": "280ms", "$type": "duration" },
      "slow":    { "$value": "480ms", "$type": "duration", "$description": "Tela de carregamento entre quiz e resultado." }
    },

    "easing": {
      "out":      { "$value": "cubic-bezier(0.4, 0, 0.2, 1)",  "$type": "cubicBezier" },
      "in":       { "$value": "cubic-bezier(0.4, 0, 1, 1)",    "$type": "cubicBezier" },
      "spring":   { "$value": "cubic-bezier(0.34, 1.4, 0.64, 1)", "$type": "cubicBezier", "$description": "Entrada de QuizOption selecionada (CSS-only fallback)." }
    },

    "stagger": {
      "$description": "Delay entre itens em listas (bullets, cards).",
      "tight":  { "$value": "60ms",  "$type": "duration" },
      "normal": { "$value": "80ms",  "$type": "duration" },
      "loose":  { "$value": "120ms", "$type": "duration" }
    },

    "spring": {
      "$description": "Spring physics — Framer Motion type='spring'. Springs modelam realidade (massa/rigidez/atrito). Use SEMPRE que possível; reserve durations puras para fade/cor.",

      "snappy": {
        "$type": "spring",
        "$value": { "stiffness": 500, "damping": 40, "mass": 0.6 },
        "$description": "Resposta a toque. Settling time ~150ms. Use em: QuizOption select, Button press, Checkbox toggle."
      },
      "gentle": {
        "$type": "spring",
        "$value": { "stiffness": 260, "damping": 26, "mass": 1 },
        "$description": "Entrada padrão de UI. Sem bounce visível. Use em: Hero entry, Card reveal, Modal in."
      },
      "bouncy": {
        "$type": "spring",
        "$value": { "stiffness": 400, "damping": 18, "mass": 1 },
        "$description": "Pop celebrativo (~10% overshoot). Use em: Result tier reveal (HOT), Pet emoji entrance, Success state."
      },
      "soft": {
        "$type": "spring",
        "$value": { "stiffness": 180, "damping": 30, "mass": 1.2 },
        "$description": "Movimento maternal/calmante. Sem overshoot. Use em: Result tier COLD, FAQ accordion, scroll-driven badge."
      }
    },

    "choreography": {
      "$description": "Variants nomeados — composições prontas. Componentes consomem variants, não recriam.",

      "fadeUp": {
        "$type": "variant",
        "$description": "Entrada padrão: 12px y-offset + opacidade. Hero text, lead, body.",
        "from":   { "opacity": 0, "y": 12 },
        "to":     { "opacity": 1, "y": 0 },
        "spring": "{motion.spring.gentle}"
      },
      "fadeIn": {
        "$type": "variant",
        "$description": "Apenas opacidade. Use quando o elemento NÃO deve sugerir direção (logos, badges, anchor word reveal).",
        "from":   { "opacity": 0 },
        "to":     { "opacity": 1 },
        "duration": "{motion.duration.base}",
        "easing":   "{motion.easing.out}"
      },
      "slideInLeft": {
        "$type": "variant",
        "$description": "Step → Step do quiz (entrada).",
        "from":   { "opacity": 0, "x": 24 },
        "to":     { "opacity": 1, "x": 0 },
        "duration": "{motion.duration.base}",
        "easing":   "{motion.easing.out}"
      },
      "slideOutLeft": {
        "$type": "variant",
        "$description": "Step → Step do quiz (saída quando Avançar).",
        "to":   { "opacity": 0, "x": -24 },
        "duration": "{motion.duration.fast}",
        "easing":   "{motion.easing.in}"
      },
      "popIn": {
        "$type": "variant",
        "$description": "Entrada com escala (emoji do pet, badge social proof).",
        "from":   { "opacity": 0, "scale": 0.92 },
        "to":     { "opacity": 1, "scale": 1 },
        "spring": "{motion.spring.bouncy}"
      },
      "tierReveal": {
        "$type": "variant",
        "$description": "Card de tier no resultado. HOT/WARM/COLD — diferentes springs por tier (intensidade emocional reforça veredito).",
        "from":   { "opacity": 0, "y": 24, "scale": 0.96 },
        "to":     { "opacity": 1, "y": 0, "scale": 1 },
        "spring_hot":  "{motion.spring.bouncy}",
        "spring_warm": "{motion.spring.gentle}",
        "spring_cold": "{motion.spring.soft}"
      },
      "pulse": {
        "$type": "variant",
        "$description": "Loop sutil no CTA primário do hero (1x a cada 4s, 1.5% de escala). Atrai sem ser desesperado.",
        "scale":    [1, 1.015, 1],
        "duration": 1200,
        "easing":   "{motion.easing.out}",
        "repeatDelay": 4000,
        "$constraint": "PROIBIDO em CTA acima de 1 pulse simultâneo por viewport."
      },
      "anchorHighlight": {
        "$type": "variant",
        "$description": "Palavra-âncora do hero (ex: 'susto'). Cor coral entra com 200ms de atraso após o headline aparecer. Reforça destaque sem trocar layout.",
        "from":   { "color": "{color.primitive.warmBlack.900}" },
        "to":     { "color": "{color.primitive.coral.500}" },
        "delay":    200,
        "duration": "{motion.duration.base}",
        "easing":   "{motion.easing.out}"
      },
      "progressFill": {
        "$type": "variant",
        "$description": "Barra de progresso. Anima scaleX (não width — width custa layout). transform-origin: left.",
        "scaleX_from": 0,
        "scaleX_to":   1,
        "duration":    "{motion.duration.slow}",
        "easing":      "{motion.easing.out}",
        "$performance": "GPU-only via transform — zero reflow."
      },
      "tap": {
        "$type": "variant",
        "$description": "Press feedback. Usa whileTap do Framer.",
        "scale":    0.98,
        "duration": "{motion.duration.instant}",
        "easing":   "{motion.easing.out}"
      },
      "shake": {
        "$type": "variant",
        "$description": "Erro/validação. Apenas em input field inválido. PROIBIDO usar fora de erro.",
        "x":        [0, -6, 6, -4, 4, 0],
        "duration": 320,
        "easing":   "{motion.easing.out}"
      }
    },

    "scroll": {
      "$description": "Animações scroll-driven. Use Intersection Observer ou Motion useScroll. Threshold 0.3 (30% visível dispara).",
      "threshold":   { "$value": 0.3, "$type": "number" },
      "rootMargin":  { "$value": "0px 0px -10% 0px", "$type": "dimension", "$description": "Dispara um pouco antes do elemento entrar (mais natural)." },
      "fadeUpDistance": { "$value": "16px", "$type": "dimension", "$description": "Distância de y-offset para reveal on-scroll. Menor que fadeUp puro pois já há contexto de scroll." }
    },

    "performance": {
      "$description": "Budget de motion. Violou = bug.",
      "frameBudgetMs":      { "$value": 16.6, "$type": "number", "$description": "60fps target. Cada frame ≤ 16.6ms." },
      "maxConcurrentSprings": { "$value": 8, "$type": "number", "$description": "Mais que isso vai estourar main thread em mobile mid-tier." },
      "gpuOnlyProperties":  { "$value": ["transform", "opacity"], "$type": "array", "$description": "Só estas animam no compositor. width/height/top/left causam layout — proibidos em loops." },
      "willChangeBudget":   { "$value": 3, "$type": "number", "$description": "Máx 3 elementos com will-change ativo simultaneamente." }
    },

    "reducedMotion": {
      "$description": "prefers-reduced-motion: reduce. Comportamento mandatório.",
      "strategy": { "$value": "preserve-fades-kill-motion", "$type": "string", "$description": "Mantém fade (informa estado), elimina movimento espacial e bounces." },
      "fadeDuration": { "$value": "0ms", "$type": "duration", "$description": "Em reduced-motion, fades também viram 0 — globals.css força via CSS." },
      "exceptions": {
        "$value": [],
        "$type": "array",
        "$description": "ZERO exceções. Sem 'animação importante demais'. Reduced motion é respeito, não negociação."
      }
    }
  },

  "zIndex": {
    "base":    { "$value": 0,    "$type": "number" },
    "raised":  { "$value": 10,   "$type": "number" },
    "sticky":  { "$value": 100,  "$type": "number" },
    "overlay": { "$value": 1000, "$type": "number" },
    "modal":   { "$value": 1100, "$type": "number" },
    "toast":   { "$value": 1200, "$type": "number" }
  },

  "breakpoint": {
    "$description": "Mobile-first. Toda peça é desenhada em 360 e cresce. Desktop é otimização, não default.",
    "sm": { "$value": "360px",  "$type": "dimension", "$description": "Mobile mínimo (iPhone SE)." },
    "md": { "$value": "768px",  "$type": "dimension", "$description": "Tablet — stack vira grid em differentiators." },
    "lg": { "$value": "1024px", "$type": "dimension" },
    "xl": { "$value": "1280px", "$type": "dimension" }
  },

  "social": {
    "$description": "Templates de social media. Dimensões fixas pelas plataformas, paddings derivados de spacing.",
    "metaFeedSquare":   { "$value": { "w": 1080, "h": 1080 }, "$type": "dimension", "$description": "Meta feed estático 1:1." },
    "metaStory":        { "$value": { "w": 1080, "h": 1920 }, "$type": "dimension", "$description": "Story/Reels 9:16." },
    "metaReelsCover":   { "$value": { "w": 1080, "h": 1920 }, "$type": "dimension" },
    "carouselSlide":    { "$value": { "w": 1080, "h": 1350 }, "$type": "dimension", "$description": "Carrossel 4:5." },
    "ogImage":          { "$value": { "w": 1200, "h": 630 },  "$type": "dimension" },
    "safeAreaStory":    {
      "$description": "Área segura — UI nativa do Instagram cobre 220px topo + 280px rodapé.",
      "topPx":    { "$value": 220, "$type": "dimension" },
      "bottomPx": { "$value": 280, "$type": "dimension" }
    }
  }
}
