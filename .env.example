# ==========================================================
# PUBLIC (bundle-side, expostos ao client)
# ==========================================================
# Deploy inicial (2026-05-12): conta Vercel "Jofi Pet's projects" (Hobby) — quota separado do team Double Check.
# Migrar para quiz.jofi.pet (ou similar) quando o time tiver acesso ao DNS do .pet.
# Substituir antes de campanhas pagas (URL .vercel.app reduz CTR em ad).
NEXT_PUBLIC_SITE_URL=https://jofipet-quiz-lp.vercel.app
NEXT_PUBLIC_META_PIXEL_ID=000000000000000
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_JOFI_WHATSAPP=558007779745
# TEMPORÁRIO (2026-05-12) — URL final do checkout Sereninho ainda não definida.
# Por enquanto, leva pro site institucional Jofi com UTMs do quiz preservados.
# Substituir antes de ir pra prod (Story 3.3 / open question #4).
NEXT_PUBLIC_SERENINHO_CHECKOUT_URL=https://jofi.pet/?utm_source=quiz_lp&utm_medium=resultado&utm_campaign=quiz_morno&utm_content=sereninho
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x0000000000000000

# ==========================================================
# SERVER-ONLY (nunca expostos — sem prefixo NEXT_PUBLIC_)
# ==========================================================

# RD Station Marketing API
# Decisão: usar Token Público da conta Jofi Pet via POST /platform/conversions
# Painel RD > Integrações > Dados de integração (API) > Token público > Copiar
# Server-only mesmo sendo "público" (evita ser scrapeado do bundle do client)
RD_STATION_PUBLIC_TOKEN=

# RD Station CRM API (diferente do RD Marketing — token próprio)
# Cria negociação (deal) automaticamente pra leads Quente + Morno.
# Painel RD CRM > Configurações > Integrações > "API e webhooks" > Token de API
# Cada usuário tem seu token. Use o token do usuário com visibilidade "Geral".
RD_CRM_TOKEN=

# ID da etapa inicial do funil que vai receber os deals (obrigatório).
# Onde achar: Configurações > Funis > escolha o funil > inspecione a primeira
# etapa. ID está na URL ou via GET /api/v1/deal_stages?token=X (lista todas).
RD_CRM_DEAL_STAGE_ID=

# Fallback: user_id pra atribuir caso a distribuição automática do funil falhe.
# Opcional. Se vazio, o RD usa as regras do próprio funil.
# Onde achar: GET https://crm.rdstation.com/api/v1/users?token=X
RD_CRM_DEFAULT_USER_ID=

# Cloudflare Turnstile
TURNSTILE_SECRET_KEY=

# Meta Conversions API (server-side tracking — driblar iOS ATT + adblockers)
# Token gerado em Meta Business → Events Manager → Pixel → Configurações → CAPI
# Mantém em segredo absoluto: dá acesso programático ao Business Manager
META_CAPI_ACCESS_TOKEN=
# Opcional: código de teste do Events Manager pra validar antes de ir ao live
META_CAPI_TEST_EVENT_CODE=

# Vercel Cron (valida header Authorization: Bearer ${CRON_SECRET})
CRON_SECRET=

# Admin panel (feature flag + credenciais)
# Senha forte recomendado: 20+ chars random. Gere com:
#   node -e "console.log(require('crypto').randomBytes(16).toString('base64'))"
# Middleware aplica: rate limit 10 tentativas/5min por IP + constant-time compare.
ADMIN_USER=pedro
ADMIN_PASSWORD=
ADMIN_PANEL_ENABLED=false

# HMAC para links de opt-out (gerar 32+ bytes hex)
HMAC_SECRET=

# Observability (opcional MVP — Epic 4)
SENTRY_DSN=

# ==========================================================
# VERCEL KV (injetadas automaticamente pelo dashboard ao conectar store)
# ==========================================================
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ==========================================================
# SUPABASE (CRM — Epic 5)
# ==========================================================
# Painel: https://supabase.com/dashboard/project/{ref}/settings/api
# Single-tenant Jofi. Postgres + Auth + Realtime.

# Server-only (service_role): writes do webhook WhatsApp, ingest de lead, jobs cron.
# NUNCA expor — bypassa RLS.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Client-side (anon key, RLS protege): UI do admin (/admin/crm/*).
# Pode ser exposta no bundle — RLS é a defesa.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ==========================================================
# WHATSAPP CLOUD API (Meta) — Epic 5
# ==========================================================
# Setup completo em docs/whatsapp-coexistence-setup.md
# Tudo gerado no Meta Business Manager da JOFI (não da DC).

# WhatsApp Business Account ID (encontra em WhatsApp Manager → Account info)
META_WABA_ID=

# Phone Number ID do número Jofi (NÃO é o número em si — é o ID interno da Meta)
META_PHONE_NUMBER_ID=

# System User Access Token PERMANENTE (não expira). Gerar em:
# Business Settings → Users → System Users → Add → gerar token com escopo
# whatsapp_business_management + whatsapp_business_messaging.
# NUNCA usar user token (expira em 24h).
META_ACCESS_TOKEN_PERMANENT=

# App Secret pra validar assinatura X-Hub-Signature-256 do webhook.
# Meta App → Settings → Basic → App Secret (revelar e copiar).
META_APP_SECRET=

# Token arbitrário que VOCÊ escolhe — Meta envia no handshake do webhook
# pra confirmar que somos donos da URL. Gerar com:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
META_WEBHOOK_VERIFY_TOKEN=

# Feature flag — desliga o disparo automático de HSM (boas-vindas pós-quiz).
# Manter 'false' enquanto os templates jofi_boasvindas_{quente,morno,frio}
# ainda não foram aprovados pela Meta (aprovação leva 24-48h).
# Quando true, ingest dispara o template correspondente ao tier do lead.
CRM_AUTO_HSM_ENABLED=false
